{
  "name": "prospeccao-new",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run --exclude='**/__tests__/integration/**' --exclude='**/__tests__/contracts/**'",
    "test:unit": "vitest run __tests__/unit/",
    "test:security": "vitest run __tests__/security/",
    "test:integration": "vitest run __tests__/integration/ __tests__/contracts/",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage --exclude='**/__tests__/integration/**' --exclude='**/__tests__/contracts/**'",
    "audit": "npm audit --audit-level=moderate",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@types/pg": "^8.16.0",
    "lru-cache": "^11.2.6",
    "next": "16.1.6",
    "pg": "^8.18.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "eslint-plugin-security": "^3.0.1",
    "happy-dom": "^20.6.3",
    "msw": "^2.12.10",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
